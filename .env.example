# HoneyTrap configuration — copy to .env and customize

# Required in production (PRODUCTION=1)
DASHBOARD_KEY=your-strong-secret-here
SECRET_KEY=random-64-char-hex-string

# Server
PORT=8000
PRODUCTION=1

# Database path (use /data/attacks.db in Docker)
DATABASE=attacks.db

# Optional: restrict dashboard to your home/office IP (comma-separated)
# Strongly recommended when exposed to the internet
# ALLOWED_DASHBOARD_IPS=203.0.113.10

# Rate limiting (logged requests per IP)
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60

# Auto-delete attacks older than N days (0 = keep forever)
RETENTION_DAYS=365

# Optional Slack/Discord webhook for new-IP alerts
# WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
